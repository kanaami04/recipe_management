# CDK デプロイ時に Lambda 環境変数へ注入するシークレット (adr/infra/0001 #5)。
# 実物は infra/.env (gitignore 済み) に置く。

# Supabase の transaction モード pooler(Supavisor, ポート 6543)の接続文字列
# (adr/infra/0002)。Supabase ダッシュボード > Connect > Transaction pooler からコピー。
# 末尾の default_query_exec_mode=simple_protocol は transaction モードの pooler で
# pgx のプリペアドステートメントを避けるため必須。
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require&default_query_exec_mode=simple_protocol

# JWT 署名鍵。`openssl rand -hex 32` などで生成する。
JWT_SECRET=

# CloudFront が /api/* に付与する X-Origin-Verify ヘッダの値 (adr/infra/0001 #3)。
# `openssl rand -hex 32` などで生成する。
ORIGIN_VERIFY_SECRET=

# プロフィール画像(アバター)まわりの Lambda 環境変数は CDK が自動設定するため、
# ここに書く必要はない: バケットは CDK が作成し、S3_ENDPOINT / 認証情報は "" を渡して
# 実 AWS + Lambda 実行ロールを使い、画像は同一オリジンの CloudFront /avatars/* で公開する。
