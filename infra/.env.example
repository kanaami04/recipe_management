# CDK デプロイ時に Lambda 環境変数へ注入するシークレット (adr/infra/0001 #5)。
# 実物は infra/.env (gitignore 済み) に置く。

# Neon の pooled 接続文字列 (adr/infra/0002)。ホスト名に -pooler が付いたもの。
# 末尾の default_query_exec_mode=simple_protocol は PgBouncer(transaction mode)で
# pgx のプリペアドステートメントを避けるため必須。
DATABASE_URL=postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&default_query_exec_mode=simple_protocol

# JWT 署名鍵。`openssl rand -hex 32` などで生成する。
JWT_SECRET=

# CloudFront が /api/* に付与する X-Origin-Verify ヘッダの値 (adr/infra/0001 #3)。
# `openssl rand -hex 32` などで生成する。
ORIGIN_VERIFY_SECRET=
