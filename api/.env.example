PORT=8000
DATABASE_URL=host=localhost user=recipe password=recipe dbname=recipe port=5433 sslmode=disable TimeZone=Asia/Tokyo
JWT_SECRET=dev-insecure-secret-change-me
CORS_ORIGIN=http://localhost:5273
LOG_LEVEL=info
LOG_FORMAT=text
# refresh Cookie に Secure 属性を付けるか (api ADR-0004)。本番(HTTPS)は true。
# dev は http の Vite proxy 経由のため false。
COOKIE_SECURE=false
# 起動時に AutoMigrate を実行するか (adr/infra/0002)。dev は true。
# Lambda はコールドスタート毎の DDL を避けるため false にし、スキーマ変更時に
# `go run . -migrate` で別途実行する。
AUTO_MIGRATE=true
# CloudFront が付与する X-Origin-Verify ヘッダの期待値 (adr/infra/0001)。
# 空なら検証しない(dev はこのまま)。本番は CloudFront の origin custom header と同じ値。
ORIGIN_VERIFY_SECRET=
