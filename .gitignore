# OS / editor
.DS_Store
# .vscode はグローバル gitignore でも無視されるため、ディレクトリごと一旦戻し、
# 共有したい settings.json だけ追跡する(親ディレクトリの除外解除が必要)
!.vscode/
.vscode/*
!.vscode/settings.json

# 個人用メモ
project/

# env
.env

# 依存・ビルド成果物(各パッケージの .gitignore に加え、ブランチ切り替え時に
# サブディレクトリの .gitignore が消えても未追跡ノイズが出ないようルートでも無視する)
node_modules/
infra/cdk.out/
infra/dist/